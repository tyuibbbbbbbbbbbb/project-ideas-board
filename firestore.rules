rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // פרופילי משתמשים - כל אחד יכול לקרוא (לתצוגת שמות), רק הבעלים יכול לכתוב
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // רעיונות - כולם יכולים לקרוא, רק מחוברים יכולים ליצור/לעדכן
    match /ideas/{ideaId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.desc is string;

      // עדכון: הצבעה (upvotes/downvotes) או אימוץ פרויקט (status/takenBy...)
      // כל משתמש מחובר יכול לעדכן - ההגבלה על אילו שדות מתבצעת בצד הלקוח
      allow update: if request.auth != null;

      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;
    }
  }
}
